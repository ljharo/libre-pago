# ===========================================
# LibrePago - Variables de Entorno
# ===========================================
# Copia este archivo a .env y ajusta los valores

# ===========================================
# Base de Datos - PostgreSQL
# ===========================================
DB_USER=admin
DB_PASSWORD=password
DB_HOST=db
DB_PORT=5432
DB_NAME=libre_pago_db

# ===========================================
# Redis
# ===========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ===========================================
# Aplicación
# ===========================================
API_KEY=test-api-key
DEBUG=false
APP_NAME=LibrePago
APP_VERSION=1.0.0

# ===========================================
# Rate Limiting
# ===========================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_IMPORT=20
RATE_LIMIT_LIST=60
RATE_LIMIT_STATS=30
RATE_LIMIT_HEALTH=200
RATE_LIMIT_WINDOW=60

# ===========================================
# Cache
# ===========================================
CACHE_ENABLED=true
CACHE_TTL_STATS=300
CACHE_TTL_LIST=60
CACHE_TTL_MAPPINGS=3600

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ===========================================
# Autenticación
# ===========================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ===========================================
# JWT
# ===========================================
JWT_SECRET=change-me-in-production-abc123xyz
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=1

# ===========================================
# Frontend (solo para desarrollo local)
# ===========================================
VITE_API_URL=http://localhost:8000
VITE_API_KEY=test-api-key
